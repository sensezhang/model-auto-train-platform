# ================================================================
# 环境变量配置模板
# 复制为 .env 并填入真实值：cp .env.example .env
# ================================================================

# ── 数据库配置 ──────────────────────────────────────────────────
# 设置此变量后，系统将使用 MySQL（不设置则默认使用 SQLite）
# 格式：mysql+pymysql://<用户名>:<密码>@<IP>:<端口>/<数据库名>
APP_DB_URL=mysql+pymysql://user:JYPI6byXTmfBQijBbptI@192.168.2.4:13306/ikingtec_power_release_dev

# SQLite 路径（仅在 APP_DB_URL 未设置时生效）
# APP_DB_PATH=./app.db

# ── OSS 对象存储配置 ─────────────────────────────────────────────
# 是否启用 OSS（true/false），默认 true
OSS_ENABLED=true

# 内网上传端点（boto3 使用，用于上传文件）
OSS_ENDPOINT=http://10.230.0.5:8009

# 公网访问域名（用于生成前端可访问的文件 URL）
OSS_PUBLIC_HOST=https://oss.ikingtec.com

# OSS 认证信息
OSS_ACCESS_KEY=123
OSS_SECRET_KEY=123

# 区域（S3 兼容协议需要）
OSS_REGION=us-east-1

# Bucket 名称（需提前在 OSS 中创建，或启动时自动创建）
OSS_BUCKET=yolo-datasets

# ── 其他配置 ─────────────────────────────────────────────────────
# 智谱 AI API Key（AI 自动标注功能需要）
# GLM_API_KEY=your_zhipuai_api_key_here

# YOLO 预训练权重目录
# YOLO_WEIGHTS_DIR=./models/weights
